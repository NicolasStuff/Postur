generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- BETTER AUTH MODELS ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?   // Required by better-auth (maps to fullName/name)
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  aiFeaturesConsentAt DateTime?

  // Better Auth Relations
  sessions      Session[]
  accounts      Account[]

  // Postur Specific Fields
  role          Role      @default(USER) // USER = Practitioner
  
  // Professional Profile
  slug             String?           @unique
  practitionerType PractitionerType?
  siret            String?
  companyName      String?
  companyAddress   String?
  isVatExempt      Boolean           @default(true)
  defaultVatRate   Decimal?          @db.Decimal(5, 2)

  // Settings
  openingHours     Json?
  slotDuration     Int               @default(60)
  language         String            @default("fr") // "fr" or "en"
  aiBetaEnabled    Boolean           @default(false)
  aiComplianceAcceptedAt DateTime?
  aiComplianceVersion String?

  // Relations
  patients         Patient[]
  appointments     Appointment[]
  services         Service[]
  invoices         Invoice[]
  subscription     Subscription?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  idToken               String?

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- POSTUR MODELS ---

enum Role {
  USER
  ADMIN
}

enum PractitionerType {
  OSTEOPATH
}

enum AppointmentStatus {
  PLANNED
  CONFIRMED
  COMPLETED
  CANCELED
  NOSHOW
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
}

enum InvoiceBuyerType {
  INDIVIDUAL
  BUSINESS
}

enum FacturXProfile {
  BASIC
  EN16931
}

enum FacturXStatus {
  INCOMPLETE
  BASIC_READY
  EN16931_CANDIDATE
}

// --- SUBSCRIPTION MODELS ---

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionPlan {
  PRO
  PRO_IA
}

model Patient {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName     String
  lastName      String
  email         String?
  phone         String?
  address       String?

  appointments  Appointment[]
  invoices      Invoice[]

  notes         String?
  medicalHistory Json?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, email])
  @@unique([id, userId])
}

model Service {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  duration      Int
  price         Decimal   @db.Decimal(10, 2)

  appointments  Appointment[]

  @@unique([id, userId])
}

model Appointment {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  patientId     String
  patient       Patient   @relation(fields: [patientId, userId], references: [id, userId])

  serviceId     String
  service       Service   @relation(fields: [serviceId, userId], references: [id, userId])

  start         DateTime
  end           DateTime
  status        AppointmentStatus @default(PLANNED)
  notes         String?
  completedAt   DateTime?
  billedAt      DateTime?

  note          ConsultationNote?
  invoice       Invoice?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([id, userId])
  @@index([userId, start])
  @@index([userId, status, start])
}

model ConsultationNote {
  id            String    @id @default(cuid())
  appointmentId String    @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  content       Json

  bodyChartHistory BodyChartHistory[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model BodyChartHistory {
  id                  String    @id @default(cuid())
  consultationNoteId  String
  consultationNote    ConsultationNote @relation(fields: [consultationNoteId], references: [id], onDelete: Cascade)

  selectedParts       String[]  // Liste des muscles/parties sélectionnés

  createdAt           DateTime  @default(now())

  @@index([consultationNoteId, createdAt])
}

model Invoice {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  patientId     String
  patient       Patient   @relation(fields: [patientId, userId], references: [id, userId])
  appointmentId String?   @unique
  appointment   Appointment? @relation(fields: [appointmentId, userId], references: [id, userId])

  number        String
  date          DateTime  @default(now())
  serviceDate   DateTime?
  dueDate       DateTime?
  currency      String    @default("EUR")
  paymentTerms  String    @default("Paiement comptant")
  buyerType     InvoiceBuyerType @default(INDIVIDUAL)
  buyerCompanyName String?
  buyerSiren    String?
  buyerVatNumber String?

  amount        Decimal   @db.Decimal(10, 2)
  vatRate       Decimal?  @db.Decimal(5, 2)
  vatAmount     Decimal?  @db.Decimal(10, 2)
  status        InvoiceStatus @default(DRAFT)
  serviceName   String?
  issuerSnapshot Json?
  patientSnapshot Json?
  lineItems     Json?
  facturXProfile FacturXProfile?
  facturXStatus FacturXStatus @default(INCOMPLETE)
  facturXXml    String?   @db.Text
  pdfUrl        String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@unique([id, userId])
  @@unique([appointmentId, userId])
  @@unique([userId, number])
  @@index([userId, date])
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String             @unique
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId      String             @unique
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?

  plan                  SubscriptionPlan   @default(PRO)
  status                SubscriptionStatus @default(TRIALING)

  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean            @default(false)

  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model WebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([stripeEventId])
}

model AuditEvent {
  id           String   @id @default(cuid())
  actorUserId  String
  targetUserId String?
  domain       String
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([domain, createdAt])
  @@index([entityType, entityId])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  scope       String
  key         String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([scope, key, windowStart])
  @@index([scope, windowStart])
}
