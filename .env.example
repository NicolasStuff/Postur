# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/postur"

# Better Auth Configuration
BETTER_AUTH_SECRET="change_me_to_a_random_secret_at_least_32_chars"
BETTER_AUTH_URL="http://localhost:3000"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_AXEPTIO_CLIENT_ID="your_axeptio_client_id"
NEXT_PUBLIC_AXEPTIO_COOKIES_VERSION="postur-fr-EU"
NEXT_PUBLIC_AXEPTIO_GOOGLE_ANALYTICS_VENDOR="google_analytics_4"
NEXT_PUBLIC_AXEPTIO_GOOGLE_ADS_VENDOR="google_ads"

# AI Providers
OPENAI_API_KEY="sk-..."
DEEPGRAM_API_KEY="dg_..."
# Optional: override default OpenAI model names
OPENAI_MODEL_MINI=
OPENAI_MODEL_FULL=

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Server-side Stripe price IDs
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_PRO_IA_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Client-side Stripe price IDs (same values, exposed to browser for checkout)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PRO_IA_PRICE_ID="price_..."

# Required for sending invoice emails via Resend
RESEND_API_KEY=
SUPPORT_NOTIFICATION_EMAIL="nicolas.ivorra.ni@gmail.com"

# Comma-separated list of trusted origins for CSRF (optional, defaults to localhost:3000 and postur.fr)
TRUSTED_ORIGINS=

# Pour la production, générez un secret aléatoire sécurisé :
# openssl rand -base64 32
